{
  "name": "e-commerce",
  "version": "0.0.1",
  "private": true,
  "scripts": {
    "build": "turbo build",
    "dev": "pnpm run dev:all",
    "lint": "biome lint apps packages/eslint-config package.json turbo.json biome.json",
    "format": "biome format --write .",
    "check": "pnpm run lint && pnpm run typecheck",
    "typecheck": "turbo typecheck",
    "dev:web": "pnpm --dir apps/web dev",
    "dev:api": "pnpm --dir apps/api dev",
    "dev:all": "concurrently -n web,api -c cyan,magenta \"pnpm run dev:web\" \"pnpm run dev:api\"",
    "smoke:postdeploy": "node scripts/post-deploy-smoke.mjs",
    "smoke:payments": "node scripts/e2e-payment-check.js"
  },
  "devDependencies": {
    "@biomejs/biome": "^1.9.4",
    "@workspace/eslint-config": "workspace:*",
    "@workspace/typescript-config": "workspace:*",
    "concurrently": "^9.2.1",
    "turbo": "^2.8.17",
    "typescript": "5.9.3"
  },
  "packageManager": "pnpm@10.33.2",
  "engines": {
    "node": ">=20"
  },
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "pnpm": {
    "onlyBuiltDependencies": [
      "@biomejs/biome",
      "@nestjs/core",
      "@prisma/engines",
      "better-sqlite3",
      "esbuild",
      "msw",
      "prisma",
      "sharp",
      "unrs-resolver"
    ]
  },
  "dependencies": {
    "lucide-react": "^1.8.0"
  }
}
