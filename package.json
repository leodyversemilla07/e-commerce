{
  "name": "e-commerce",
  "version": "0.0.1",
  "private": true,
  "scripts": {
    "build": "turbo build",
    "dev": "bun run dev:all",
    "lint": "biome lint apps packages/eslint-config package.json turbo.json biome.json",
    "format": "biome format --write .",
    "check": "biome check .",
    "typecheck": "turbo typecheck",
    "dev:web": "bun --cwd apps/web dev",
    "dev:api": "bun --cwd apps/api dev",
    "dev:all": "concurrently -n web,api -c cyan,magenta \"bun run dev:web\" \"bun run dev:api\"",
    "smoke:postdeploy": "node scripts/post-deploy-smoke.mjs",
    "smoke:payments": "node scripts/e2e-payment-check.js"
  },
  "devDependencies": {
    "@biomejs/biome": "^1.9.4",
    "@workspace/eslint-config": "workspace:*",
    "@workspace/typescript-config": "workspace:*",
    "concurrently": "^9.2.1",
    "turbo": "^2.8.17",
    "typescript": "5.9.3"
  },
  "packageManager": "bun@1.3.12",
  "engines": {
    "node": ">=20"
  },
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "dependencies": {
    "lucide-react": "^1.8.0"
  }
}
