# Web app
NEXT_PUBLIC_AUTH_BASE_URL=http://localhost:4000

# Better Auth (API)
BETTER_AUTH_URL=http://localhost:4000
BETTER_AUTH_SECRET=change-me-to-a-long-random-string-at-least-32-characters
BETTER_AUTH_TRUSTED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# API
PORT=4000
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/ecommerce_dev?schema=public
ADMIN_PASSWORD=change-me-admin-password

# Email (password reset)
# Get a free API key at https://resend.com — omit to fall back to console logging (local dev only)
RESEND_API_KEY=re_***
# Must be a verified sender domain in your Resend account
RESEND_FROM_EMAIL=no-reply@yourdomain.com

# Payments
# Supported: mock | stripe
PAYMENT_PROVIDER=mock
# Required when PAYMENT_PROVIDER=stripe
STRIPE_SECRET_KEY=sk_***
# Required for Stripe webhook signature verification
STRIPE_WEBHOOK_SECRET=whsec_***
